{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pairwise compatibility rule registry",
  "type": "object",
  "required": ["schema_version", "last_reviewed", "severity_order", "substance_classes", "rules"],
  "properties": {
    "schema_version": {"type": "string"},
    "last_reviewed": {"type": "string"},
    "severity_order": {"type": "array", "items": {"type": "string"}, "minItems": 5},
    "substance_classes": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}}},
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rule_id", "version", "status", "a", "b", "phase_contexts", "mechanism", "severity", "confidence", "mitigations", "validation", "source_refs"],
        "properties": {
          "rule_id": {"type": "string"},
          "version": {"type": "integer", "minimum": 1},
          "status": {"enum": ["active", "draft", "retired"]},
          "a": {"$ref": "#/$defs/selector"},
          "b": {"$ref": "#/$defs/selector"},
          "phase_contexts": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "mechanism": {"type": "string"},
          "severity": {"enum": ["pass", "advisory", "marginal", "block", "unknown"]},
          "confidence": {"enum": ["low", "medium", "high"]},
          "mitigations": {"type": "array", "items": {"type": "string"}},
          "downgrade_contexts": {"type": "object", "additionalProperties": {"type": "string"}},
          "validation": {"type": "array", "items": {"type": "string"}},
          "source_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
        }
      }
    }
  },
  "$defs": {
    "selector": {
      "type": "object",
      "oneOf": [
        {"required": ["key"]},
        {"required": ["class"]}
      ],
      "properties": {
        "key": {"type": "string"},
        "class": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
